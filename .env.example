# Environment Variables Template
# Copy this file to .env and fill in your values

# =============================================================================
# Backend Configuration
# =============================================================================

# Environment mode (dev, prod, test)
ENV=dev

# Debug mode (enable detailed error messages)
DEBUG=true

# Disable security features (for development convenience)
DISABLE_SECURITY=false

# Base URL (frontend address)
BASE_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256

# osu! OAuth Configuration
OSU_CLIENT_ID=your-osu-client-id
OSU_CLIENT_SECRET=your-osu-client-secret

# PostgreSQL Connection (Docker service name)
POSTGRESQL_HOST=postgres
POSTGRESQL_PORT=5432
POSTGRESQL_USERNAME=postgres
# Database password (must be secure if prod)
POSTGRESQL_PASSWORD=postgres
# Database name (dev: graveboards_dev, prod: graveboards_prod, test: graveboards_test)
POSTGRESQL_DATABASE=graveboards_dev

# Redis Connection (Docker service name)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# Logging Configuration
# LOG_FORMAT=text|json (default: text)
# Use json for Loki/Promtail log aggregation compatibility
LOG_FORMAT=text

# =============================================================================
# Frontend Configuration
# =============================================================================

# Public API URL (browser)
NEXT_PUBLIC_API_URL=/api/v1

# Backend API URL (server-side)
INTERNAL_API_URL=http://localhost:8000/api/v1

# Session signing key
SESSION_SECRET=your-session-secret

# Canonical public origin — source of truth for absolute URLs / redirects
APP_URL=http://localhost:3000

# =============================================================================
# Testing Configuration
# =============================================================================

# Test database (different from dev/prod)
POSTGRES_DB_TEST=graveboards_test

# Test Redis DB (different from dev/prod)
REDIS_DB_TEST=15

# =============================================================================
# Storage Configuration (Production/NAS)
# =============================================================================

# PostgreSQL data directory (NAS mounts)
POSTGRESQL_DATA_PATH=postgresql-data

# Redis data directory (NAS mounts)
REDIS_DATA_PATH=redis-data

# Backend instance directory (NAS mounts)
INSTANCE_DATA_PATH=instance-data

# =============================================================================
# Monitoring Configuration
# =============================================================================

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=password
GRAFANA_ROOT_URL=http://localhost:3001

# Alertmanager Discord webhook URL (required for alerts to fire)
# Create a webhook in your Discord server: Server Settings > Integrations > Webhooks
ALERTMANAGER_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
