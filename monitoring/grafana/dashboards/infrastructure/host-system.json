      },
      "targets": [
        {
          "expr": "100 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100",
          "legendFormat": "CPU used %",
          "refId": "A"
        }
      ],
      "title": "CPU Used %",
      "description": "Host CPU utilization. Amber >70%, red >90%.",
      "type": "stat"
    },
