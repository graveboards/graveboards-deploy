{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Log Volume by Level",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "sum(count_over_time({service=~\"$service\"}[5m])) by (level)",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "loglines/s" },
        "overrides": []
      }
    },
    {
      "title": "Log Volume by Logger",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "sum(count_over_time({service=~\"$service\"}[5m])) by (logger)",
          "legendFormat": "{{logger}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "loglines/s" },
        "overrides": []
      }
    },
    {
      "title": "Error Count (Last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "sum(count_over_time({service=~\"$service\", level=\"ERROR\"}[1h]))",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Warning Count (Last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "sum(count_over_time({service=~\"$service\", level=~\"WARN(ING)?\"}[1h]))",
          "legendFormat": "Warnings",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "sum(rate({service=~\"$service\", logger=\"app\"} |=\"HTTP\" [5m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "title": "Errors by Logger",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "sum(count_over_time({service=~\"$service\", level=\"ERROR\"}[1h])) by (logger)",
          "legendFormat": "{{logger}}"
        }
      ]
    },
    {
      "title": "Top Error Messages",
      "type": "table",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "topk(10, count_over_time({service=~\"$service\", level=\"ERROR\"}[1h]))",
          "legendFormat": "{{message}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "width": 300
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Request ID Trace",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "{service=~\"$service\", request_id=\"$request_id\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false,
        "dedupStrategy": "none",
        "enableInfiniteScrolling": false
      }
    },
    {
      "title": "Live Log Stream",
      "type": "logs",
      "gridPos": { "h": 16, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "{service=~\"$service\"} | level=~\"$level\" | logger=~\"$logger\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false,
        "dedupStrategy": "none",
        "enableInfiniteScrolling": false
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["graveboards", "logs"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "Loki" },
        "query": "label_values(service)",
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "current": { "text": ["All"], "value": ["$__all"] }
      },
      {
        "name": "level",
        "type": "custom",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "label": "Level",
        "options": [
          { "text": "All", "value": "$__all", "selected": false },
          { "text": "DEBUG", "value": "DEBUG", "selected": false },
          { "text": "INFO", "value": "INFO", "selected": false },
          { "text": "WARNING", "value": "WARNING", "selected": false },
          { "text": "ERROR", "value": "ERROR", "selected": false }
        ],
        "query": "DEBUG,INFO,WARNING,ERROR",
        "current": { "text": ["All"], "value": ["$__all"] }
      },
      {
        "name": "logger",
        "type": "query",
        "datasource": { "type": "loki", "uid": "Loki" },
        "query": "label_values({service=~\"$service\"}, logger)",
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "current": { "text": ["All"], "value": ["$__all"] }
      },
      {
        "name": "request_id",
        "type": "textbox",
        "hide": 0,
        "label": "Request ID",
        "query": "",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Graveboards Logs",
  "uid": "graveboards-logs"
}
