{
  "annotations": {
    "list": [
      {
        "builtIn": 0,
        "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
        "enable": true,
        "expr": "count(ALERTS{alertstate=\"firing\"}) > 0",
        "hide": false,
        "iconColor": "red",
        "name": "Firing Alerts",
        "showIn": 0,
        "textFormat": "{{alertname}}",
        "titleFormat": "Firing Alerts",
        "type": "tags"
      }
    ]
  },
  "description": "search_requests_total/search_duration_seconds record successful searches only; failed/invalid search requests appear in API & Requests → Errors as error_type=bad_request.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": true,
      "dashboards": [
        { "tags": ["graveboards"] }
      ],
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false,
      "title": "Dashboards",
      "type": "dashboards"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "KPIs",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "amber", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(rate(search_requests_total[5m]))",
          "legendFormat": "Rate",
          "refId": "A"
        }
      ],
      "title": "Request Rate",
      "description": "Search requests per second over the last 5 minutes.",
      "links": [
        {
          "title": "View Platform Overview",
          "url": "/d/graveboards-overview?from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "amber", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "links": [
        {
          "title": "View Platform Overview",
          "url": "/d/graveboards-overview?from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(search_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "title": "p95 Duration",
      "description": "Search p95 latency. Amber >0.5s, red >2s.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "amber", "value": 80 },
              { "color": "green", "value": 90 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "links": [
        {
          "title": "View Platform Overview",
          "url": "/d/graveboards-overview?from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "sum(rate(search_cache_hits_total[5m])) / (sum(rate(search_cache_hits_total[5m])) + sum(rate(search_cache_misses_total[5m]))) * 100",
          "legendFormat": "Cache Hit %",
          "refId": "A"
        }
      ],
      "title": "Cache Hit Ratio (Windowed)",
      "description": "Application-level search cache hit ratio, windowed with rate(). Green >90%, amber 80-90%, red <80%. Note: queues scope is never cached and will always read 0%.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "links": [
        {
          "title": "View Platform Overview",
          "url": "/d/graveboards-overview?from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "sum(increase(search_requests_total[24h]))",
          "legendFormat": "Total (24h)",
          "refId": "A"
        }
      ],
      "title": "Total Requests (24h)",
      "description": "Total search requests in the last 24 hours.",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "title": "Traffic by Scope",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "auto"
          },
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "beatmaps" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "beatmapsets" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "scores" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#EAB839", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "queues" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "requests" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 7,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-logger=app.search&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "sum(rate(search_requests_total[5m])) by (scope)",
          "legendFormat": "{{scope}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Scope",
      "description": "Search request rate grouped by scope (beatmaps, beatmapsets, scores, queues, requests).",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "auto"
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*p50.*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*p95.*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#EAB839", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 8,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-logger=app.search&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(search_duration_seconds_bucket[5m])) by (le, scope))",
          "legendFormat": "{{scope}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(search_duration_seconds_bucket[5m])) by (le, scope))",
          "legendFormat": "{{scope}} p95",
          "refId": "B"
        }
      ],
      "title": "Duration p50 / p95 by Scope",
      "description": "50th and 95th percentile search duration by scope. Green = p50, amber = p95.",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 9,
      "title": "Cache Effectiveness",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "amber", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          },
          "unit": "percent"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "queues" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#808080", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 10,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-logger=app.search&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(rate(search_cache_hits_total[5m])) by (scope) / (sum(rate(search_cache_hits_total[5m])) by (scope) + sum(rate(search_cache_misses_total[5m])) by (scope)) * 100",
          "legendFormat": "{{scope}}",
          "refId": "A"
        }
      ],
      "title": "Cache Hit Ratio by Scope (Windowed)",
      "description": "Per-scope cache hit ratio. Note: queues scope is never cached (results depend on caller identity) and will always read 0% — this is expected, not broken.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "auto"
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*hits.*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*misses.*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 11,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-logger=app.search&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "sum(rate(search_cache_hits_total[5m])) by (scope)",
          "legendFormat": "{{scope}} hits",
          "refId": "A"
        },
        {
          "expr": "sum(rate(search_cache_misses_total[5m])) by (scope)",
          "legendFormat": "{{scope}} misses",
          "refId": "B"
        }
      ],
      "title": "Hits vs Misses by Scope",
      "description": "Cache hits and misses per scope. queues scope has only misses (never cached).",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 12,
      "title": "Search Logs",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 24 },
      "id": 13,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "enableLogDetailsOpenClose": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "timestampFormat": "2006-01-02 15:04:05"
      },
      "targets": [
        {
          "expr": "{service=~\"$service\"} | json | logger=~\"app.search.*\" | request_id=~\"$request_id\" |= \"$search\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Search Request Stream",
      "description": "Search-related log lines. Filter by request_id to trace a single search through validation, caching, and query execution.",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["graveboards", "search"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
        "multi": false,
        "name": "datasource_prometheus",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Loki",
        "multi": false,
        "name": "datasource_loki",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": { "selected": false, "text": "backend", "value": "backend" },
        "hide": 0,
        "includeAll": true,
        "label": "Service",
        "multi": true,
        "name": "service",
        "options": [],
        "query": "label_values(service)",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query",
        "datasource": { "type": "loki", "uid": "${datasource_loki}" }
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": true,
        "label": "Scope",
        "multi": true,
        "name": "scope",
        "options": [],
        "query": "label_values(search_requests_total, scope)",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "label": "Request ID",
        "name": "request_id",
        "options": [],
        "query": "",
        "skipUrlSync": false,
        "type": "textbox"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "label": "Search",
        "name": "search",
        "options": [],
        "query": "",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Search",
  "uid": "graveboards-search",
  "version": 1
}
