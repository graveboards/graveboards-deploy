    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "amber", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 11,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-logger=app.osu_api&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
