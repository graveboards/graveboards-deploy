        "showHeader": true,
        "sortBy": [
          { "desc": true, "displayName": "Rate" }
        ]
      },
      "targets": [
        {
          "expr": "topk(10, sum(rate(osu_api_errors_total[5m])) by (endpoint, error_type))",
          "legendFormat": "{{endpoint}} / {{error_type}}",
          "refId": "A"
        }
      ],
      "title": "Errors by Endpoint & Type",
      "description": "Top 10 endpoint/error_type combinations by rate.",
      "type": "table"
    },
