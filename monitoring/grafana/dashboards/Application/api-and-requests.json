      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "amber", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 33 },
      "id": 17,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-service=backend&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
