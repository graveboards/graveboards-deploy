          "expr": "topk(10, sum(rate(http_requests_total{status_code=~\"4..|5..\"}[5m])) by (endpoint) / sum(rate(http_requests_total[5m])) by (endpoint) * 100)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
