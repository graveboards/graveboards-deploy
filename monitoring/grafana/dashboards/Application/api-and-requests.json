{
  "annotations": {
    "list": [
      {
        "builtIn": 0,
        "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
        "enable": true,
        "expr": "ALERTS{alertstate=\"firing\"}",
        "hide": false,
        "iconColor": "red",
        "name": "Firing Alerts",
        "showIn": 0,
        "textFormat": "{{alertname}}",
        "titleFormat": "Firing Alerts",
        "type": "tags"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": true,
      "dashboards": [
        { "tags": ["graveboards"] }
      ],
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false,
      "title": "Dashboards",
      "type": "dashboards"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "RED KPIs",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "amber", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "job:http_requests:rate5m",
          "legendFormat": "Rate",
          "refId": "A"
        }
      ],
      "title": "Request Rate",
      "description": "Total requests per second over the last 5 minutes.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "amber", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "job:http_requests_errors:ratio5m * 100",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "title": "Error Rate",
      "description": "5xx error rate as a percentage. Amber >1%, red >5%.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "amber", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "job:http_request_duration:p95_5m",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "title": "p95 Latency",
      "description": "95th percentile latency. Amber >0.5s, red >2s.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(http_requests_in_flight)",
          "legendFormat": "In-Flight",
          "refId": "A"
        }
      ],
      "title": "In-Flight",
      "description": "Currently in-flight requests.",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "title": "Rate & Errors",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed" },
          "custom": {
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "auto"
          },
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "2xx" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "3xx" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "4xx" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#EAB839", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "5xx" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 7,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-service=backend&var-level=error&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"2..\"}[5m]))",
          "legendFormat": "2xx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"3..\"}[5m]))",
          "legendFormat": "3xx",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"4..\"}[5m]))",
          "legendFormat": "4xx",
          "refId": "C"
        },
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx",
          "refId": "D"
        }
      ],
      "title": "Request Rate by Status Class",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed" },
          "custom": {
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "amber", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "4xx %" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#EAB839", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "5xx %" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 8,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-service=backend&var-level=error&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"4..\"}[5m])) / sum(rate(http_requests_total[5m])) * 100",
          "legendFormat": "4xx %",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m])) * 100",
          "legendFormat": "5xx %",
          "refId": "B"
        }
      ],
      "title": "Error Ratio 4xx vs 5xx",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 9,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed" },
          "custom": {
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "auto"
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p50" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#EAB839", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 10,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-service=backend&var-level=error&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Latency Percentiles p50 / p95 / p99",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": {
            "scheme": "hot",
            "mode": "opacity"
          },
          "custom": {
            "fillOpacity": 100,
            "lineWidth": 0,
            "gradientMode": "scheme",
            "scale": "log"
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 11,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-service=backend&var-level=error&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {
          "exponent": 0.5,
          "fill": "dark-orange",
          "mode": "scheme",
          "reverse": false,
          "scale": "exponential",
          "scheme": "Hot",
          "steps": 64
        },
        "exemplars": {
          "color": "rgba(255,0,255,0.7)"
        },
        "filterValues": {
          "le": 1e-9
        },
        "rowsFrame": {
          "layout": "auto"
        },
        "tooltip": {
          "mode": "single",
          "showColorScale": false,
          "yHistogram": false
        },
        "yAxis": {
          "axisPlacement": "left",
          "reverse": false,
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(http_request_duration_seconds_bucket[5m])) by (le)",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "title": "Latency Heatmap",
      "type": "heatmap"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 12,
      "title": "Endpoints",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "endpoint" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View logs for this endpoint",
                    "url": "/d/graveboards-logs?var-service=backend&var-logger=app.access&var-search=${__value.text}&from=${__from}&to=${__to}",
                    "targetBlank": false
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "id": 13,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-service=backend&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          { "desc": true, "displayName": "Rate" }
        ]
      },
      "targets": [
        {
          "expr": "topk(10, sum(rate(http_requests_total[5m])) by (endpoint))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "title": "Endpoints by Rate",
      "description": "Top 10 endpoints by request rate.",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "displayMode": "color-background",
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "amber", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "endpoint" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View logs for this endpoint",
                    "url": "/d/graveboards-logs?var-service=backend&var-logger=app.access&var-search=${__value.text}&from=${__from}&to=${__to}",
                    "targetBlank": false
                  }
                ]
              },
              { "id": "custom.displayMode", "value": "auto" }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "id": 19,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-service=backend&var-level=error&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          { "desc": true, "displayName": "Value" }
        ]
      },
      "targets": [
        {
          "expr": "topk(10, sum(rate(http_requests_total{status_code=~\"4..|5..\"}[5m])) by (endpoint) / sum(rate(http_requests_total[5m])) by (endpoint) * 100)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "title": "Endpoints by Error %",
      "description": "Top 10 endpoints by 4xx/5xx error percentage.",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "inspect": false
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "endpoint" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View logs for this endpoint",
                    "url": "/d/graveboards-logs?var-service=backend&var-logger=app.access&var-search=${__value.text}&from=${__from}&to=${__to}",
                    "targetBlank": false
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "id": 20,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-service=backend&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          { "desc": true, "displayName": "Value" }
        ]
      },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, endpoint)))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "title": "Endpoints by p95 Latency",
