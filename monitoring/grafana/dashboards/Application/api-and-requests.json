    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "id": 21,
      "title": "API Requests",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 10, "w": 8, "x": 0, "y": 42 },
      "id": 22,
      "options": {
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": false,
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum by (auth_scheme) (count_over_time({service=~\"$service\"} | json | logger=\"app.access\" | user_id=~\"$user_id\" [$__range]))",
          "legendFormat": "{{auth_scheme}}",
          "refId": "A"
        }
      ],
      "title": "Requests by Auth Type",
      "description": "Who's calling the API: bearer (JWT user), api_key, or none (guest/unauthenticated). Grouped by the `auth_scheme` JSON field emitted by app.access.",
