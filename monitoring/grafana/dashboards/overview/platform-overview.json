{
  "annotations": {
    "list": [
      {
        "builtIn": 0,
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "enable": true,
        "expr": "count(ALERTS{alertstate=\"firing\"}) > 0",
        "hide": false,
        "iconColor": "red",
        "name": "Firing Alerts",
        "showIn": 0,
        "textFormat": "{{alertname}}",
        "titleFormat": "Firing Alerts",
        "type": "tags"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": true,
      "dashboards": [
        { "tags": ["graveboards"] }
      ],
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false,
      "title": "Dashboards",
      "type": "dashboards"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "center",
            "displayMode": "basic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "bool_on_off"
        }
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "up{job=~\"graveboards-backend|postgres|redis|node|prometheus|alertmanager\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Service Health",
      "description": "Scrape target health. Green = up, red = down.",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 3,
      "title": "Alerts",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "amber", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 6 },
      "id": 4,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\"})",
          "legendFormat": "Firing",
          "refId": "A"
        }
      ],
      "title": "Firing Alerts",
      "description": "Number of currently firing alerts.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "gridPos": { "h": 4, "w": 16, "x": 8, "y": 6 },
      "id": 5,
      "options": {
        "alertInstanceLabelFilter": "",
        "alertName": "",
        "dashboardAlerts": false,
        "groupBy": [],
        "groupMode": "default",
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": {
          "error": true,
          "firing": true,
          "inactive": true,
          "noData": false,
          "normal": true,
          "pending": true
        },
        "warnForState": false
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
          "refId": "A"
        }
      ],
      "title": "Alert List",
      "type": "alertlist"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "id": 6,
      "title": "Golden Signals",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "amber", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 11 },
      "id": 7,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "job:http_requests:rate5m",
          "legendFormat": "Rate",
          "refId": "A"
        }
      ],
      "title": "Request Rate",
      "description": "Requests per second over the last 5 minutes.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "amber", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 11 },
      "id": 8,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "job:http_requests_errors:ratio5m * 100",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "title": "Error Rate",
      "description": "5xx error rate as a percentage. Amber >1%, red >5%.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "amber", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 11 },
      "id": 9,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "job:http_request_duration:p95_5m",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "title": "p95 Latency",
      "description": "95th percentile latency. Amber >0.5s, red >2s.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 11 },
      "id": 10,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(http_requests_in_flight)",
          "legendFormat": "In-Flight",
          "refId": "A"
        }
      ],
      "title": "In-Flight",
      "description": "Currently in-flight requests.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "amber", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 11 },
      "id": 11,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(rate(osu_api_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(osu_api_requests_total[5m])) * 100",
          "legendFormat": "osu! Error %",
          "refId": "A"
        }
      ],
      "title": "osu! API Error %",
      "description": "osu! API 5xx error rate. Amber >1%, red >10%.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 5 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 11 },
      "id": 12,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(daemon_service_running)",
          "legendFormat": "Running",
          "refId": "A"
        }
      ],
      "title": "Daemon Services",
      "description": "Number of daemon services currently running (out of 5).",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 13,
      "title": "Subsystem Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "id": 14,
      "links": [
        {
          "title": "View API & Requests",
          "url": "/d/graveboards-api?from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "job:http_requests:rate5m",
          "legendFormat": "Request rate",
          "refId": "A"
        },
        {
          "expr": "job:http_requests_errors:ratio5m * 100",
          "legendFormat": "Error %",
          "refId": "B"
        }
      ],
      "title": "API Traffic",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 16 },
      "id": 15,
      "links": [
        {
          "title": "View Host / System",
          "url": "/d/graveboards-host?from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "instance:node_cpu_utilization:ratio5m * 100",
          "legendFormat": "CPU %",
          "refId": "A"
        },
        {
          "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "legendFormat": "Memory %",
          "refId": "B"
        }
      ],
      "title": "Infrastructure",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 16 },
      "id": 16,
      "links": [
        {
          "title": "View PostgreSQL",
          "url": "/d/graveboards-postgres?from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count) / pg_settings_max_connections * 100",
          "legendFormat": "PG Connections %",
          "refId": "A"
        },
        {
          "expr": "redis_memory_used_bytes / redis_memory_max_bytes * 100",
          "legendFormat": "Redis Memory %",
          "refId": "B"
        }
      ],
      "title": "Data Stores",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 17,
      "title": "Recent Errors",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }
        }
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 23 },
      "id": 18,
      "links": [
        {
          "title": "View Logs Explorer",
          "url": "/d/graveboards-logs?var-service=backend&var-level=error&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "sum(rate({service=\"backend\", level=\"error\"}[5m]))",
          "legendFormat": "Error rate",
          "refId": "A"
        }
      ],
      "title": "Backend Error Log Rate",
      "description": "Rate of error-level log lines from the backend. Links to Logs Explorer filtered to level=error.",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
