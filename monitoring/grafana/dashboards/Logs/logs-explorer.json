{
  "annotations": {
    "list": [
      {
        "builtIn": 0,
        "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
        "enable": true,
        "expr": "count(ALERTS{alertstate=\"firing\"}) > 0",
        "hide": false,
        "iconColor": "red",
        "name": "Firing Alerts",
        "showIn": 0,
        "textFormat": "{{alertname}}",
        "titleFormat": "Firing Alerts",
        "type": "tags"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": true,
      "dashboards": [
        { "tags": ["graveboards"] }
      ],
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false,
      "title": "Dashboards",
      "type": "dashboards"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Log Health",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "amber", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\", level=\"error\"}[$__range]))",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ],
      "title": "Error Count",
      "description": "Total error-level log lines in the selected time range. Amber >10, red >50.",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "amber", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\", level=\"warning\"}[$__range]))",
          "legendFormat": "Warnings",
          "refId": "A"
        }
      ],
      "title": "Warning Count",
      "description": "Total warning-level log lines in the selected time range. Amber >5, red >20. Zero means no warnings were emitted.",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "logs/s"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(rate({service=~\"$service\"}[$__range]))",
          "legendFormat": "Log rate",
          "refId": "A"
        }
      ],
      "title": "Total Log Rate",
      "description": "Rate of all log lines across all levels and services, in logs per second.",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\"}[$__range]))",
          "legendFormat": "Total lines",
          "refId": "A"
        }
      ],
      "title": "Total Log Lines",
      "description": "Total log lines across all levels in the selected time range.",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "title": "Volume & Distribution",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed" },
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "debug" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#969696", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "info" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#7EB26D", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "warning" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#EAB839", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "critical" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#A50000", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "id": 7,
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\"}[$__interval])) by (level)",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "title": "Log Volume by Level",
      "description": "Log lines grouped by level label. Colored: debug=grey, info=blue, warning=amber, error=red, critical=dark-red.",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "amber", "value": 5 },
              { "color": "green", "value": 10 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 8,
      "options": {
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "topk(10, sum(count_over_time({service=~\"$service\", level=\"error\"} | json [$__range])) by (logger))",
          "legendFormat": "{{logger}}",
          "refId": "A"
        }
      ],
      "title": "Errors by Logger",
      "description": "Top 10 loggers by error count, grouped by the `logger` JSON field. Inverted thresholds: red = no errors, amber = some errors, green = many errors (healthy logger activity).",
      "type": "bargauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 24,
      "title": "Error Types",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed" },
          "custom": {
            "align": "auto",
            "displayMode": "color-background",
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "exception" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-text"
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 25,
      "links": [
        {
          "title": "View full log stream",
          "url": "/d/graveboards-logs?var-service=backend&var-level=error&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          { "desc": true, "displayName": "Count" }
        ]
      },
      "targets": [
        {
          "expr": "topk(10, sum(count_over_time({service=~\"$service\", level=\"error\"} | json | exception=~\".*\" [$__range])) by (exception))",
          "legendFormat": "{{exception}}",
          "refId": "A"
        }
      ],
      "title": "Errors by Exception Type",
      "description": "Top 10 exception types from error-level logs. Based on the `exception` field emitted by structlog's format_exc_info processor.",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed" },
          "custom": {
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "auto"
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "bad_request" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#EAB839", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "internal_server_error" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "forbidden" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "unauthorized" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#F2CC04", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 26,
      "links": [
        {
          "title": "View API & Requests",
          "url": "/d/graveboards-api?from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "job:errors_by_type:rate5m",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ],
      "title": "Error Rate by Type (Metric Correlation)",
      "description": "Correlates with the errors_total metric. See API & Requests → Errors for the full breakdown.",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 9,
      "title": "Log Stream",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 23 },
      "id": 10,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "enableLogDetailsOpenClose": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "timestampFormat": "2006-01-02 15:04:05"
      },
      "targets": [
        {
          "expr": "{service=~\"$service\", level=~\"$level\"} | json | logger=~\"$logger\" | request_id=~\"$request_id\" |= \"$search\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Log Stream",
      "description": "Full log stream with JSON parsing. Each exception appears as one expandable row (multiline fixed).",
      "type": "logs"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 52 },
      "id": 27,
      "title": "Search",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 53 },
      "id": 28,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "enableLogDetailsOpenClose": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "timestampFormat": "2006-01-02 15:04:05"
      },
      "targets": [
        {
          "expr": "{service=~\"$service\"} | json | logger=~\"app.search.*\" | request_id=~\"$request_id\" |= \"$search\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Search Request Stream",
      "description": "Search-related log lines. Filter by request_id to trace a single search through validation, caching, and query execution.",
      "type": "logs"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "id": 29,
      "title": "API Requests",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 10, "w": 8, "x": 0, "y": 40 },
      "id": 16,
      "options": {
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": false,
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum by (auth_scheme) (count_over_time({service=~\"$service\"} | json | logger=\"app.access\" | user_id=~\"$user_id\" [$__range]))",
          "legendFormat": "{{auth_scheme}}",
          "refId": "A"
        }
      ],
      "title": "Requests by Auth Type",
      "description": "Who's calling the API: bearer (JWT user), api_key, or none (guest/unauthenticated). Grouped by the `auth_scheme` JSON field emitted by app.access.",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "gridPos": { "h": 10, "w": 16, "x": 8, "y": 40 },
      "id": 17,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "enableLogDetailsOpenClose": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "timestampFormat": "2006-01-02 15:04:05"
      },
      "targets": [
        {
          "expr": "{service=~\"$service\"} | json | logger=\"app.access\" | user_id=~\"$user_id\" |= \"$search\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "API Request Stream",
      "description": "Every app.access line, filtered to just this logger. Expand a row's Log details to see the full parsed request: query_params, body (redacted, JSON/form bodies ≤ 8KB only), user_id, and auth_scheme, alongside the existing method/path/status/duration summary. Filter to one caller with the User ID variable above.",
      "type": "logs"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 63 },
      "id": 30,
      "title": "Daemon Services",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 64 },
      "id": 31,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "enableLogDetailsOpenClose": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "timestampFormat": "2006-01-02 15:04:05"
      },
      "targets": [
        {
          "expr": "{service=~\"$service\"} | json | logger=~\"app.daemon.*\" | request_id=~\"$request_id\" |= \"$search\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Daemon Service Stream",
      "description": "Log lines from daemon services (profile_fetcher, score_fetcher, rule_validation, queue_request_handler, etc.). Filter by request_id to trace individual jobs.",
      "type": "logs"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 76 },
      "id": 21,
      "title": "Audit",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 77 },
      "id": 22,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "enableLogDetailsOpenClose": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "timestampFormat": "2006-01-02 15:04:05"
      },
      "targets": [
        {
          "expr": "{service=~\"$service\"} | json | logger=~\".*audit.*\" | action=~\"$audit_action\" |= \"$search\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Audit Log Stream",
      "description": "Audit events from the app. Each row shows the action, user_id, entity_type, entity_id, and ip_address from the structured audit log output. Filter by action with the Audit Action variable.",
      "type": "logs"
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 89 },
      "id": 18,
      "title": "Infrastructure & Stack",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 90 },
      "id": 19,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "enableLogDetailsOpenClose": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "timestampFormat": "2006-01-02 15:04:05"
      },
      "targets": [
        {
          "expr": "{service=~\"postgresql|redis\"} |= \"$search\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Infrastructure Logs",
      "description": "Plain-text postgresql and redis container logs. Deliberately not JSON-parsed (they aren't JSON) — kept separate from the main Log Stream to avoid JSONParserErr/unknown-level noise.",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 90 },
      "id": 20,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "enableLogDetailsOpenClose": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "timestampFormat": "2006-01-02 15:04:05"
      },
      "targets": [
        {
          "expr": "{service=~\"prometheus|grafana|alertmanager|loki|promtail\"} |= \"$search\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Monitoring Stack Logs",
      "description": "stdout/stderr from the observability stack: prometheus, grafana, alertmanager, loki, and promtail. Useful for debugging the monitoring pipeline itself.",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["graveboards", "logs"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Loki",
        "multi": false,
        "name": "datasource_loki",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
        "multi": false,
        "name": "datasource_prometheus",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": { "selected": false, "text": "backend", "value": "backend" },
        "hide": 0,
        "includeAll": true,
        "label": "Service",
        "multi": true,
        "name": "service",
        "options": [],
        "query": "label_values(service)",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query",
        "datasource": { "type": "loki", "uid": "${datasource_loki}" }
      },
      {
        "current": { "selected": false, "text": "All", "value": ["__all"] },
        "hide": 0,
        "includeAll": true,
        "label": "Level",
        "multi": true,
        "name": "level",
        "options": [
          { "selected": false, "text": "debug", "value": "debug" },
          { "selected": false, "text": "info", "value": "info" },
          { "selected": false, "text": "warning", "value": "warning" },
          { "selected": false, "text": "error", "value": "error" },
          { "selected": false, "text": "critical", "value": "critical" }
        ],
        "query": "debug,info,warning,error,critical",
        "skipUrlSync": false,
        "type": "custom"
      },
      {
        "current": { "selected": false, "text": ".*", "value": ".*" },
        "hide": 0,
        "label": "Logger",
        "name": "logger",
        "options": [],
        "query": ".*",
        "skipUrlSync": false,
        "type": "textbox"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "label": "Search",
        "name": "search",
        "options": [],
        "query": "",
        "skipUrlSync": false,
        "type": "textbox"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "label": "Request ID",
