{
  "annotations": {
    "list": [
      {
        "builtIn": 0,
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "enable": true,
        "expr": "count(ALERTS{alertstate=\"firing\"}) > 0",
        "hide": false,
        "iconColor": "red",
        "name": "Firing Alerts",
        "showIn": 0,
        "textFormat": "{{alertname}}",
        "titleFormat": "Firing Alerts",
        "type": "tags"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": true,
      "dashboards": [
        { "tags": ["graveboards"] }
      ],
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false,
      "title": "Dashboards",
      "type": "dashboards"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Log Health",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "amber", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\", level=\"error\"}[$__range]))",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ],
      "title": "Error Count",
      "description": "Total error-level log lines in the selected range.",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "amber", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\", level=\"warning\"}[$__range]))",
          "legendFormat": "Warnings",
          "refId": "A"
        }
      ],
      "title": "Warning Count",
      "description": "Total warning-level log lines. 0 = none emitted (not necessarily broken).",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "logs/s"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(rate({service=~\"$service\"}[$__range]))",
          "legendFormat": "Log rate",
          "refId": "A"
        }
      ],
      "title": "Total Log Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\"}[$__range]))",
          "legendFormat": "Total lines",
          "refId": "A"
        }
      ],
      "title": "Total Log Lines",
      "description": "Total log lines across all levels in the selected time range.",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "title": "Volume & Distribution",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed" },
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "debug" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "super-light-purple", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "info" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "warning" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "amber", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "critical" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "dark-red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "id": 7,
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\"}[$__interval])) by (level)",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "title": "Log Volume by Level",
      "description": "Log lines grouped by level label. Colored: debug=grey, info=blue, warning=amber, error=red, critical=dark-red.",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "amber", "value": 5 },
              { "color": "green", "value": 10 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 8,
      "options": {
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "topk(10, sum(count_over_time({service=~\"$service\", level=\"error\"} | json [$__range])) by (logger))",
          "legendFormat": "{{logger}}",
          "refId": "A"
        }
      ],
      "title": "Errors by Logger",
      "description": "Top 10 loggers by error count. Grouped by the `logger` JSON field.",
      "type": "bargauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 9,
      "title": "Log Stream",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 15 },
      "id": 10,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "enableLogDetailsOpenClose": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "timestampFormat": "2006-01-02 15:04:05",
        "direction": "bottom"
      },
      "targets": [
        {
          "expr": "{service=~\"$service\", level=~\"$level\"} | json | logger=~\"$logger\" | request_id=~\"$request_id\" |= \"$search\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Log Stream",
      "description": "Full log stream with JSON parsing. Each exception appears as one expandable row (multiline fixed).",
      "type": "logs"
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 11,
      "title": "Correlation Helpers",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "auto"
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 12,
      "targets": [
        {
          "expr": "sum(rate({service=\"backend\"} | json | logger=\"app.access\" [5m]))",
          "legendFormat": "Access log rate",
          "refId": "A"
        }
      ],
      "title": "HTTP Access Log Rate",
      "description": "Rate of access log lines. Uses `logger=\"app.access\"` (the JSON field, not `logger_name`).",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource_loki}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 13,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "enableLogDetailsOpenClose": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "timestampFormat": "2006-01-02 15:04:05",
        "direction": "bottom"
      },
      "targets": [
        {
          "expr": "{service=~\"$service\"} | json | request_id=\"$request_id\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Request-ID Trace",
      "description": "Paste a request ID to see all log lines for that request. Activates once the backend emits `request_id` (companion Phase 1).",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["graveboards", "logs"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Loki",
        "multi": false,
        "name": "datasource_loki",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": { "selected": false, "text": "All", "value": ["__all"] },
        "hide": 0,
        "includeAll": true,
        "label": "Service",
        "multi": true,
        "name": "service",
        "options": [],
        "query": "label_values(service)",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "All", "value": ["__all"] },
        "hide": 0,
        "includeAll": true,
        "label": "Level",
        "multi": true,
        "name": "level",
        "options": [
          { "selected": false, "text": "debug", "value": "debug" },
          { "selected": false, "text": "info", "value": "info" },
          { "selected": false, "text": "warning", "value": "warning" },
          { "selected": false, "text": "error", "value": "error" },
          { "selected": false, "text": "critical", "value": "critical" }
        ],
        "query": "debug,info,warning,error,critical",
        "skipUrlSync": false,
        "type": "custom"
      },
      {
        "current": { "selected": false, "text": ".*", "value": ".*" },
        "hide": 0,
        "label": "Logger",
        "name": "logger",
        "options": [],
        "query": ".*",
        "skipUrlSync": false,
        "type": "textbox"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "label": "Search",
        "name": "search",
        "options": [],
        "query": "",
        "skipUrlSync": false,
        "type": "textbox"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "label": "Request ID",
        "name": "request_id",
        "options": [],
        "query": "",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Logs Explorer",
  "uid": "graveboards-logs",
  "version": 1
}
