{
  "annotations": {
    "list": [
      {
        "builtIn": 0,
        "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
        "enable": true,
        "expr": "count(ALERTS{alertstate=\"firing\"}) > 0",
        "hide": false,
        "iconColor": "red",
        "name": "Firing Alerts",
        "showIn": 0,
        "textFormat": "{{alertname}}",
        "titleFormat": "Firing Alerts",
        "type": "tags"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": true,
      "dashboards": [
        { "tags": ["graveboards"] }
      ],
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false,
      "title": "Dashboards",
      "type": "dashboards"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Redis Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "bool_on_off"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "redis_up",
          "legendFormat": "Redis Up",
          "refId": "A"
        }
      ],
      "title": "Redis Up",
      "description": "Whether Redis is reachable by the exporter. 1 = up, 0 = down.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "amber", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "redis_memory_used_bytes / redis_memory_max_bytes * 100",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ],
      "title": "Memory Used %",
      "description": "Redis memory as % of maxmemory. Amber >70%, red >90%.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "links": [
        {
          "title": "View Host / System",
          "url": "/d/graveboards-host?from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "Clients",
          "refId": "A"
        }
      ],
      "title": "Connected Clients",
      "description": "Number of currently connected Redis clients.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "amber", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(rate(redis_keyspace_hits_total[5m])) / (sum(rate(redis_keyspace_hits_total[5m])) + sum(rate(redis_keyspace_misses_total[5m]))) * 100",
          "legendFormat": "Server Hit %",
          "refId": "A"
        }
      ],
      "title": "Server Cache Hit Ratio",
      "description": "Redis server-side cache hit ratio (hits / hits+misses). Green >95%, amber 90-95%, red <90%.",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "title": "Server Internals",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "auto"
          },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "id": 7,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-logger=app.redis&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total[5m])",
          "legendFormat": "Commands/s",
          "refId": "A"
        }
      ],
      "title": "Ops / sec",
      "description": "Rate of Redis commands processed, in commands per second.",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "auto"
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "id": 8,
      "links": [
        {
          "title": "View Host / System",
          "url": "/d/graveboards-host?from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        },
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-logger=app.redis&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "Used",
          "refId": "A"
        }
      ],
      "title": "Memory Over Time",
      "description": "Redis memory usage in bytes over time. Compare against host memory (Host / System dashboard) for context.",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "auto"
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 9,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-logger=app.redis&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "rate(redis_evicted_keys_total[5m])",
          "legendFormat": "evictions",
          "refId": "A"
        },
        {
          "expr": "rate(redis_expired_keys_total[5m])",
          "legendFormat": "expirations",
          "refId": "B"
        }
      ],
      "title": "Evictions & Expirations",
      "description": "Rate of evicted keys (forced out due to memory pressure — the key Redis incident signal) and expired keys (TTL-based expiry). Any sustained eviction rate indicates memory is too low.",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 24,
      "title": "Keyspace & Reloads",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "auto"
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 25,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-logger=app.redis&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "redis_db_keys",
          "legendFormat": "db{{db}}",
          "refId": "A"
        }
      ],
      "title": "Keyspace by DB",
      "description": "Key counts per logical DB. Type-level breakdown requires --check-keys exporter flag.",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "auto"
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 26,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-logger=app.redis&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "changes(redis_rdb_last_save_timestamp_seconds[1h])",
          "legendFormat": "RDB saves/hour",
          "refId": "A"
        },
        {
          "expr": "redis_uptime_in_seconds",
          "legendFormat": "Uptime",
          "refId": "B"
        }
      ],
      "title": "Server Reloads & Uptime",
      "description": "RDB save frequency and Redis uptime. Uptime resets flag unexpected Redis restarts, which redis_up alone won't catch if restart happens between scrapes.",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 10,
      "title": "App Command Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "auto"
          },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 11,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-logger=app.redis&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "sum(rate(redis_commands_total[5m])) by (command)",
          "legendFormat": "{{command}}",
          "refId": "A"
        }
      ],
      "title": "Command Throughput by Type",
      "description": "Rate of Redis commands grouped by type (GET, SET, HSET, etc.), in commands per second.",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "auto"
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 12,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-logger=app.redis&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(redis_commands_duration_seconds_bucket[5m])) by (le, command))",
          "legendFormat": "{{command}} p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(redis_commands_duration_seconds_bucket[5m])) by (le, command))",
          "legendFormat": "{{command}} p50",
          "refId": "B"
        }
      ],
      "title": "Command Latency p95 / p50 by Type",
      "description": "95th and 50th percentile command execution time by type. Spikes indicate Redis is struggling to keep up.",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 13,
      "title": "App Cache Effectiveness",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "amber", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 14,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-logger=app.redis&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(rate(redis_cache_hits_total[5m])) / (sum(rate(redis_cache_hits_total[5m])) + sum(rate(redis_cache_misses_total[5m]))) * 100",
          "legendFormat": "App Hit %",
          "refId": "A"
        }
      ],
      "title": "App Cache Hit Rate (Windowed)",
      "description": "Application-level cache hit ratio, windowed with rate(). Green >95%, amber >90%, red <90%.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "auto"
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 15,
      "links": [
        {
          "title": "View Logs",
          "url": "/d/graveboards-logs?var-logger=app.redis&from=${__from}&to=${__to}",
          "targetBlank": false,
          "type": "link"
        }
      ],
      "targets": [
        {
          "expr": "sum(rate(redis_cache_hits_total[5m]))",
          "legendFormat": "hits",
          "refId": "A"
        },
        {
          "expr": "sum(rate(redis_cache_misses_total[5m]))",
          "legendFormat": "misses",
          "refId": "B"
        }
      ],
      "title": "Cache Hits vs Misses",
      "description": "Application-level cache hits and misses rate. Complements the App Cache Hit Rate stat above — watch for rising misses which indicate cache stress or a cold cache after restart.",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
