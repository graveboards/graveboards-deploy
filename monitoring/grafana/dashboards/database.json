{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Connection Pool Utilization",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "db_pool_checked_out",
          "legendFormat": "Checked Out",
          "refId": "A"
        },
        {
          "expr": "db_pool_checked_in",
          "legendFormat": "Checked In",
          "refId": "B"
        },
        {
          "expr": "db_pool_size",
          "legendFormat": "Pool Size",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Overflow Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "db_pool_overflow",
          "legendFormat": "Overflow",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Pool Utilization %",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "db_pool_checked_out / db_pool_size * 100",
          "legendFormat": "Utilization",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } },
        "overrides": []
      }
    },
    {
      "title": "Query Duration by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(db_query_duration_seconds_bucket[5m])) by (le, query_type))",
          "legendFormat": "{{query_type}} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "title": "Query Rate by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(db_query_duration_seconds_count[5m])) by (query_type)",
          "legendFormat": "{{query_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Qps" },
        "overrides": []
      }
    },
    {
      "title": "Query Duration Histogram",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(db_query_duration_seconds_bucket[5m])) by (le)",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Slow Queries (>1s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(increase(db_query_duration_seconds_count{le=\"1\"}[5m]))",
          "legendFormat": "Queries < 1s",
          "refId": "A"
        },
        {
          "expr": "sum(increase(db_query_duration_seconds_count{le=\"+Inf\"}[5m])) - sum(increase(db_query_duration_seconds_count{le=\"1\"}[5m]))",
          "legendFormat": "Queries >= 1s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["graveboards", "database"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Database",
  "uid": "graveboards-database",
  "version": 1
}
