# Graveboards Backup CronJobs
# Add these to your crontab with: crontab -e

# Daily backup at 2:00 AM
0 2 * * * cd /path/to/graveboards-deploy && ./backup.sh >> /var/log/graveboards-backup.log 2>&1

# Weekly backup on Sunday at 3:00 AM (full backup with different naming)
0 3 * * 0 cd /path/to/graveboards-deploy && ./backup.sh --weekly >> /var/log/graveboards-backup.log 2>&1

# Monthly backup on 1st at 4:00 AM (monthly backup)
0 4 1 * * cd /path/to/graveboards-deploy && ./backup.sh --monthly >> /var/log/graveboards-backup.log 2>&1
