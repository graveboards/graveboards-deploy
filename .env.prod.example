ENV=prod
DEBUG=false
DISABLE_SECURITY=false
BASE_URL=http://localhost:3000
JWT_SECRET_KEY=your-production-jwt-secret-key
JWT_ALGORITHM=HS256
ADMIN_USER_IDS=your-admin-user-ids
OSU_CLIENT_ID=your-osu-client-id
OSU_CLIENT_SECRET=your-osu-client-secret
POSTGRESQL_PASSWORD=your-secure-postgres-password
SESSION_SECRET=your-32-character-session-secret

# Database name
POSTGRESQL_DATABASE=graveboards_prod

# =========================
# Volume Configuration
# =========================

# Choose your storage mode by uncommenting the appropriate section:

# Option A: Docker named volumes (default, easy setup)
POSTGRESQL_DATA_PATH=postgresql-prod-data
REDIS_DATA_PATH=redis-prod-data
INSTANCE_DATA_PATH=instance-prod-data

# Option B: NAS/external mounts (production)
# Set these paths to your external mount points:
# POSTGRES_DATA_PATH=/var/nas/graveboards/postgresql
# REDIS_DATA_PATH=/var/nas/graveboards/redis
# INSTANCE_DATA_PATH=/var/nas/graveboards/instance
